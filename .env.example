# Copia este archivo como ".env" (en la raiz del proyecto) y reemplaza los valores.
# El archivo ".env" real NUNCA debe subirse al repositorio (ya esta en .gitignore).

# Password del usuario "sa" de SQL Server dentro del contenedor db.
# Minimo 8 caracteres, con mayuscula, minuscula, numero y simbolo.
SA_PASSWORD=EligeUnaPasswordSegura123!

# Secreto usado para firmar los JWT de autenticacion.
# Minimo 32 caracteres. Generalo con: openssl rand -base64 48
JWT_SECRET=EligeUnSecretoLargoYAleatorioDeAlMenos32Caracteres
